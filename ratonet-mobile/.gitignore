# ==============================================================================
# 🛡️ RATONET MOBILE — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔐 SEGREDOS E CREDENCIAIS (NUNCA VERSIONAR!)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
# Manter apenas o .env.example (template sem valores reais)
!.env.example

# Chaves nativas do Google/Firebase (contém SHA e IDs de projeto)
google-services.json
GoogleService-Info.plist

# Certificados e chaves criptográficas
*.pem
*.key
*.jks
*.p8
*.p12
*.keystore
*.mobileprovision
*serviceAccountKey*.json
*firebase-adminsdk*.json
credentials.json

# ------------------------------------------------------------------------------
# 📦 DEPENDÊNCIAS
# ------------------------------------------------------------------------------
node_modules/

# ------------------------------------------------------------------------------
# 📱 EXPO
# ------------------------------------------------------------------------------
.expo/
dist/
web-build/
expo-env.d.ts

# Pasta gerada pelo expo run:android / run:ios
/ios/
/android/

# ------------------------------------------------------------------------------
# 🏗️ BUILD E CACHE
# ------------------------------------------------------------------------------
.metro-health-check*
*.tsbuildinfo
.cache/
coverage/

# ------------------------------------------------------------------------------
# 📝 LOGS E DEBUG
# ------------------------------------------------------------------------------
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ------------------------------------------------------------------------------
# 💻 SISTEMA OPERACIONAL
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# 🖊️ IDEs
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.sln
*.swp
